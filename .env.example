SPRING_PROFILES_ACTIVE=prod

DB_NAME=skep_db
DB_USER=skep_user
DB_PASSWORD=change-me
DB_PORT=5433

REDIS_PORT=6380

BACKEND_PORT=8081
FRONTEND_PORT=8082

# 로컬 테스트 계정 자동 시드 (bp1/equipment1/manpower1 @example.com)
# 프로덕션에선 false 또는 환경변수에서 제거
SKEP_BOOTSTRAP_TEST_USERS_ENABLED=true

# ===========================================================
# OnlyOffice 인플레이스 편집 (선택, Phase S-8.4)
# ===========================================================
# 활성화 절차:
#   1) ONLYOFFICE_JWT_SECRET 을 16자 이상 랜덤 문자열로 설정 (예: openssl rand -hex 32)
#   2) ONLYOFFICE_ENABLED=true
#   3) docker compose --profile onlyoffice up -d
#   4) 브라우저에서 http://localhost:8083 접속해 헬스체크 (Document Server welcome 페이지)
# 운영 환경:
#   - HTTPS 필수 (mixed content 차단). 리버스 프록시 + 인증서.
#   - ONLYOFFICE_URL 을 브라우저가 접근하는 공개 URL 로 변경 (예: https://office.example.com).
#   - PUBLIC_BACKEND_URL 도 같은 도메인의 공개 backend URL 로 변경.
ONLYOFFICE_ENABLED=false
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_URL=http://localhost:8083
ONLYOFFICE_PORT=8083
PUBLIC_BACKEND_URL=http://backend:8080

# ===========================================================
# verify-server 통합 (선택, Phase S-9-G) — 사업자등록증 OCR + 정부 API 검증
# ===========================================================
# 활성화 절차:
#   1) 아래 키들을 발급받아 채움
#   2) VERIFY_ENABLED=true
#   3) docker compose --profile verify --profile onlyoffice up -d (또는 verify 만)
#   4) backend 재시작 — 자동으로 OCR + NTS 라우팅 활성화
VERIFY_ENABLED=false
VERIFY_API_KEY=                    # main-api ↔ verify-api 내부 인증 키 (랜덤 32자)
VERIFY_MAIN_API_URL=http://main-api:8080
VERIFY_INNER_API_URL=http://verify-api:8081

# Google Cloud Vision OCR — 사업자등록증/면허/안전교육 이미지 텍스트 추출
# https://console.cloud.google.com/apis/library/vision.googleapis.com 활성화 + API 키 발급
GOOGLE_VISION_API_KEY=

# 공공데이터포털 사업자등록상태조회 API — 계속/휴업/폐업 자동 검증
# https://www.data.go.kr/data/15081808/openapi.do 신청
NTS_API_SERVICE_KEY=

# (선택) 추가 정부 API
PUBLIC_API_SERVICE_KEY=            # 면허 검증 lcnsCheckService
RIMS_API_URL=                      # 도로교통공단 운전면허
RIMS_AUTH_KEY=
RIMS_SECRET_KEY=
TS_CAR_API_KEY=                    # 한국교통안전공단 자동차 등록정보

# skep-v2 backend 자체 NTS 클라이언트 (verify-server 우회 옵션)
# verify-api 미가동 시에도 사업자번호만으로 NTS 자동검증 가능.
NTS_SERVICE_KEY=
