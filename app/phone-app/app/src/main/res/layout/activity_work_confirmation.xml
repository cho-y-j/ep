<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#2563EB"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="‹"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@null"
            android:padding="0dp"
            android:minWidth="0dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="작업확인서 사인"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 작업 정보"
                android:textSize="13sp"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <include layout="@layout/item_info_row" android:id="@+id/rowDate" />
                <include layout="@layout/item_info_row" android:id="@+id/rowAuto" />
                <include layout="@layout/item_info_row" android:id="@+id/rowBreak" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="총 근무시간 (조정 가능)"
                android:textSize="13sp"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etHours"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:textSize="18sp"
                    android:textColor="#0F172A"
                    android:gravity="end"
                    android:hint="0.00"
                    android:textColorHint="#CBD5E1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="시간"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비고 (선택)"
                android:textSize="13sp"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etRemarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:gravity="top"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:textSize="13sp"
                android:hint="휴식 추가, 작업 변경 등"
                android:textColorHint="#94A3B8"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="작업자 사인"
                    android:textSize="13sp"
                    android:textColor="#0F172A"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnClear"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="지우기"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:backgroundTint="#FFFFFF"
                    android:paddingHorizontal="10dp"
                    android:minWidth="0dp" />
            </LinearLayout>

            <com.dainon.skep.ui.SignaturePadView
                android:id="@+id/sigPad"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="사인 후 제출"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2563EB"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="· 사인 후 제출하면 BP 확인 단계로 넘어갑니다.\n· 휴식 1시간 자동 차감되어 있습니다."
                android:textSize="11sp"
                android:textColor="#64748B"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
